# Password you'll type into /admin to add & edit spots
ADMIN_PASSWORD=changeme123

# --- Vercel KV (Upstash Redis) ---
# These are auto-filled by Vercel when you add the "KV" (Upstash) storage
# integration from your project's Storage tab. You don't need to set these
# by hand on Vercel. For local development, copy the values Vercel shows you
# into a .env.local file so `npm run dev` can read/write real data too.
# If these are left blank, the app falls back to a local JSON file at
# data/spots.json — great for local testing, but it will NOT persist on
# Vercel's live site (serverless filesystem resets on every deploy).
KV_REST_API_URL=
KV_REST_API_TOKEN=
